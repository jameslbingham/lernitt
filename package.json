{
  "name": "lernitt-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-server": "cd server && npm install",
    "install-client": "cd client && npm install",
    "build-client": "cd client && npm run build",
    "build": "npm run install-server && npm run install-client && npm run build-client",
    "start": "cd server && node server.js",
    "cleanup:recordings": "node server/scripts/cleanupRecordings.js",
    "client:dev": "cd client && npm run dev",
    "server:dev": "cd server && node server.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "@google/generative-ai": "^0.21.0",
    "@paypal/payouts-sdk": "^1.0.1",
    "@sendgrid/mail": "^7.7.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "crypto": "^1.0.1",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.3",
    "node-fetch": "^2.6.7",
    "nodemailer": "^6.9.8",
    "stripe": "^11.17.0"
  }
}
